{
	"name": "sass-fairy",
	"private": true,
	"workspaces": [
		"packages/*",
		"website"
	],
	"author": {
		"name": "roydukkey",
		"email": "contact@changelog.me",
		"url": "http://changelog.me"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/roydukkey/sass-fairy.git"
	},
	"homepage": "https://github.com/roydukkey/sass-fairy#readme",
	"bugs": {
		"url": "https://github.com/roydukkey/sass-fairy/issues"
	},
	"keywords": [
		"sass",
		"scss",
		"dart-sass"
	],
	"devDependencies": {
		"@rollup/plugin-json": "^4.1.0",
		"@roydukkey/eslint-config": "^1.0.12",
		"@tsconfig/node12": "^1.0.9",
		"@typescript-eslint/eslint-plugin": "^5.25.0",
		"@typescript-eslint/parser": "^5.25.0",
		"clean-package": "^2.1.1",
		"cross-env": "^7.0.3",
		"cspell": "^5.19.3",
		"eslint": "^8.15.0",
		"eslint-plugin-tsdoc": "^0.2.16",
		"fs-extra": "^10.0.1",
		"glob": "^8.0.3",
		"jest": "^28.1.0",
		"jest-environment-node-single-context": "^28.0.0",
		"replace-in-file": "^6.3.2",
		"rollup": "^2.73.0",
		"rollup-plugin-ts": "^2.0.7",
		"rollup-plugin-license": "^2.7.0",
		"sass": "^1.51.0",
		"sass-true": "^6.1.0",
		"typescript": "^4.6.4"
	},
	"engines": {
		"npm": "please-use-yarn",
		"yarn": ">= 1.22.0"
	},
	"scripts": {
		"clean": "yarn clean:src && yarn clean:website",
		"clean:src": "node -e \"require('glob')('./packages/**/dist', (_, files) => files.forEach((path) => fs.rmSync(path, { recursive: true, force: true })))\"",
		"clean:website": "yarn workspace website clear",
		"serve": "yarn workspace website start",
		"deploy": "cross-env GIT_USER=roydukkey USE_SSH=true yarn workspace website deploy",
		"build": "rollup --config ./rollup.config.ts --configPlugin rollup-plugin-ts",
		"lint": "yarn clean && yarn lint:spelling && yarn lint:src && yarn lint:website",
		"lint:spelling": "cspell --config './.vscode/cSpell.json' --no-progress '**/{.*/**/,.*/**/.,,.}*'",
		"lint:src": "eslint --ext js,jsx,ts,tsx ./",
		"lint:website": "yarn workspace website lint",
		"pretest": "yarn lint:spelling",
		"test": "jest"
	},
	"jest": {
		"testEnvironment": "jest-environment-node-single-context",
		"verbose": true,
		"coverageDirectory": ".jest/coverage",
		"cacheDirectory": ".jest/cache"
	},
	"eslintConfig": {
		"extends": [
			"@roydukkey/eslint-config"
		],
		"env": {
			"node": true
		},
		"ignorePatterns": [
			"website"
		],
		"overrides": [
			{
				"files": [
					"*.js?(x)"
				],
				"rules": {
					"@typescript-eslint/no-require-imports": "off"
				}
			},
			{
				"files": [
					"*.{j,t}s?(x)"
				],
				"rules": {
					"@typescript-eslint/naming-convention": [
						"error",
						{
							"selector": "default",
							"format": [
								"camelCase"
							],
							"filter": {
								"regex": "^sass-fairy_[a-z]+_[a-z-]+\\(",
								"match": false
							}
						},
						{
							"selector": "default",
							"modifiers": [
								"unused"
							],
							"format": [
								"camelCase"
							],
							"leadingUnderscore": "require"
						},
						{
							"selector": [
								"typeLike",
								"enumMember"
							],
							"format": [
								"PascalCase"
							]
						},
						{
							"selector": "property",
							"modifiers": [
								"private"
							],
							"format": [
								"camelCase"
							],
							"leadingUnderscore": "require"
						},
						{
							"selector": "interface",
							"format": [
								"PascalCase"
							],
							"custom": {
								"regex": "^I[A-Z]",
								"match": false
							}
						}
					]
				}
			}
		]
	}
}
