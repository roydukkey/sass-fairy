{
	"//": [
		"Several properties of this file will be derived from the project's root ",
		"package.json while packing. This is done to avoid duplication and to ",
		"help maintain symmetry between packages."
	],
	"name": "@sass-fairy/exception",
	"description": "Provides Sass functions to standardize exception messages and assist with common validation",
	"version": "1.1.0",
	"keywords": [
		"throw",
		"error",
		"warn"
	],
	"main": "./dist/exception-functions.js",
	"publishDependencies": {
		"sass": "^1.51.0"
	},
	"optionalDependencies": {
		"@sass-fairy/break": ">=1.0.0",
		"@sass-fairy/color": ">=1.0.0",
		"@sass-fairy/list": ">=1.0.0",
		"@sass-fairy/map": ">=1.0.0",
		"@sass-fairy/math": ">=1.0.0",
		"@sass-fairy/meta": ">=1.0.0",
		"@sass-fairy/string": ">=1.0.0"
	},
	"scripts": {
		"new:pack": "clean-package && yarn pack && clean-package restore --config $npm_package_clean_package",
		"new:publish": "clean-package && yarn publish && clean-package restore --config $npm_package_clean_package"
	},
	"clean-package": "../../clean-package.config.js",
	"publishConfig": {
		"access": "public"
	}
}
